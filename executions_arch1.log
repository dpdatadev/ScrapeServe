<script>
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchForm = document.getElementById('searchForm');
   
    document.body.addEventListener('htmx:afterSwap', function(event) {
        if (event.target.id === 'searchResults') {
            event.target.classList.remove('hidden');
        }
    });

    searchInput.addEventListener('focusout', function() {
        setTimeout(() => {
                searchResults.classList.add('hidden');
        }, 200); 
    });

    searchForm.addEventListener('submit', function(){
        searchResults.classList.add('hidden');
    });
    
    document.body.addEventListener('htmx:afterSwap', function(event) {
        if (event.target.id === 'page') {
            initializeAllCarousels();
            initializeRecaptcha(event.target);
        }
    });

    // code for the carousels blocks
    document.addEventListener('DOMContentLoaded', function () {
        initializeAllCarousels();
        initializeMobileMenu();

        window.addEventListener('popstate', function () {
            initializeAllCarousels();
        });
    });

    document.addEventListener('htmx:afterSwap', function (event) {
        initializeAllCarousels();
        initializeRecaptcha(event.target);  // Ensure reCAPTCHA is initialized after each HTMX swap
        initializeMobileMenu();

        var cancelScrollHeader = event.detail.xhr.getResponseHeader('HX-Cancel-Scroll');

        if (!cancelScrollHeader) {
            // Default behavior: smooth scrolling
            if (event.target.id == "page") {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                event.target.scrollIntoView({ behavior: 'smooth' });
            }
        } 
    });

    function initializeAllCarousels() {
        // Find all elements with the class 'glide'
        document.querySelectorAll('.glide').forEach(function (carouselElement, index) {
            let carouselId = `carousel-${index + 1}`;

            if (carouselElement.id) {
                if (carouselElement.glide) {
                    carouselElement.glide.destroy();
                }
            }

            carouselElement.id = carouselId;

            // Get the number of slides in the carousel
            let slides = carouselElement.querySelectorAll('.glide__slide').length;

            // Determine the perView value based on the number of slides
            let perView = Math.min(slides, 5);

            let glide = new Glide(`#${carouselId}`, {
                type: 'carousel',
                perView: perView,
                focusAt: 0,
                gap: 10,
                autoplay: 10000,
                hoverpause: true,
                rewind: false,
                breakpoints: {
                    1024: {
                        perView: Math.min(slides, 3)
                    },
                    768: {
                        perView: Math.min(slides, 2)
                    },
                    480: {
                        perView: Math.min(slides, 1)
                    }
                }
            });

            glide.mount();

            // Save the Glide instance to the carousel element for later reference
            carouselElement.glide = glide;
        });

        // Reapply htmx attributes
        reapplyHTMXAttributes();
    }

    function reapplyHTMXAttributes() {
        document.querySelectorAll('a.play-now-button').forEach(function (element) {
            element.setAttribute('hx-get', element.getAttribute('data-hx-get'));
            element.setAttribute('hx-target', element.getAttribute('data-hx-target'));
            element.setAttribute('hx-select', element.getAttribute('data-hx-select'));
            element.setAttribute('hx-swap', element.getAttribute('data-hx-swap'));
            element.classList.add('htmx-request');
        });
    }

    function initializeMobileMenu() {
        var mobileMenuButton = document.getElementById('mobileMenuButton');
        var mobileMenu = document.getElementById('mobileMenu');
        if (!mobileMenuButton || !mobileMenu) {
            return;
        }

        // Remove previous listeners by cloning the node
        var newButton = mobileMenuButton.cloneNode(true);
        mobileMenuButton.parentNode.replaceChild(newButton, mobileMenuButton);
        mobileMenuButton = newButton;

        mobileMenuButton.addEventListener('click', function () {
            var isHidden = mobileMenu.classList.contains('hidden');
            if (isHidden) {
                mobileMenu.classList.remove('hidden');
                mobileMenuButton.setAttribute('aria-expanded', 'true');
            } else {
                mobileMenu.classList.add('hidden');
                mobileMenuButton.setAttribute('aria-expanded', 'false');
            }
        });

        // Close when resizing up to desktop
        window.addEventListener('resize', function () {
            if (window.innerWidth >= 768) {
                if (!mobileMenu.classList.contains('hidden')) {
                    mobileMenu.classList.add('hidden');
                    mobileMenuButton.setAttribute('aria-expanded', 'false');
                }
            }
        });
    }

    // captcha code
    function initializeRecaptcha(parentNode) {
        grecaptcha.ready(function() {
            grecaptcha.execute('6LdRRB8sAAAAAOewm6h1-uixz1e19oN2moaTiDbg', {action: 'submit'}).then(function(token) {
                var recaptchaInput = parentNode.querySelector('input[name="recaptcha_token"]');
                if (recaptchaInput) {
                    recaptchaInput.value = token;
                }
            });
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        var contactForm = document.getElementById('contactForm');
        if (contactForm) {
            contactForm.addEventListener('submit', function(event) {
                event.preventDefault();
                initializeRecaptcha(contactForm);
            });

            document.body.addEventListener('htmx:afterSwap', function(evt) {
                if (evt.detail.target.id === "form-content") {
                    initializeRecaptcha(contactForm);
                }
            });

            // Initial reCAPTCHA setup
            initializeRecaptcha(contactForm);
        }
        var newsletterForm = document.getElementById('newsletterForm');
        if (newsletterForm) {
            newsletterForm.addEventListener('submit', function(event) {
                event.preventDefault();
                initializeRecaptcha(newsletterForm);
            });

            document.body.addEventListener('htmx:afterSwap', function(evt) {
                if (evt.detail.target.id === "news-form-content") {
                    initializeRecaptcha(newsletterForm);
                }
            });

            // Initial reCAPTCHA setup
            initializeRecaptcha(newsletterForm);
        }
    });
</script>


